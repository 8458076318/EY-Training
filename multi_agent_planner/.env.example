# ── App ──────────────────────────
APP_NAME="Multi-Agent Day Planner"
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Agent API Keys ────────────────
OPENAI_API_KEY=sk-...           # Required — only paid key
GROQ_API_KEY=gsk_...            # Free at console.groq.com
OLLAMA_BASE_URL=http://localhost:11434  # Local ollama

# ── SMS Reminders (pick one) ──────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# OR (India):
# FAST2SMS_API_KEY=...

# ── Vector DB (pick one) ──────────
USE_PINECONE=false
PINECONE_API_KEY=pcsk_...
FAISS_INDEX_PATH=data/faiss_index

# ── Infrastructure ────────────────
REDIS_URL=redis://localhost:6379
PROMETHEUS_PORT=8001
# SENTRY_DSN=https://...
